# Auth Token for requests made to Mesastream. This should be a long, random string.
AUTH_TOKEN=changeme

REDIS_URI=redis://:changeme@redis:6379

OTLP_ENDPOINT=http://openobserve:5081
OTLP_AUTH="Basic your_base64_encoded_auth_token"
OTLP_ORGANIZATION=black-mesa

# Optional configuration for Mesastream
RUST_LOG=info,mesastream=debug
PORT=8070
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
FFMPEG_BITRATE_KBPS=128
AUDIO_CACHE_PATH=/var/cache/mesastream/audio
